# =========================================
# Server Configuration
# =========================================
APP_NAME=FreeIPA Self-Service Portal
APP_ENV=development              # development | production
APP_HOST=0.0.0.0
APP_PORT=8080

# Comma-separated allowed origins for CORS (frontend URL)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# =========================================
# JWT Configuration
# =========================================
# IMPORTANT: generate dengan: openssl rand -base64 64
JWT_SECRET=change-me-please-use-a-very-long-random-secret-min-64-chars
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_HOURS=8
JWT_ISSUER=ai-be-sre

# =========================================
# FreeIPA / LDAP Configuration
# =========================================
LDAP_SERVER_URL=ldaps://ipa.example.com:636
LDAP_USER_BASE_DN=cn=users,cn=accounts,dc=example,dc=com
LDAP_GROUP_BASE_DN=cn=groups,cn=accounts,dc=example,dc=com

# Service account untuk operasi admin (reset password user lain, list users)
LDAP_BIND_DN=uid=pwreset-svc,cn=users,cn=accounts,dc=example,dc=com
LDAP_BIND_PASSWORD=change-me

# Nama group FreeIPA yang dianggap admin app ini.
# User di group ini bisa akses dashboard admin.
LDAP_ADMIN_GROUP=admins

# TLS settings
LDAP_USE_TLS=true
LDAP_VERIFY_CERT=true

# =========================================
# SMTP Relay Configuration
# =========================================
# SMTP relay biasanya tanpa auth (di-trust by IP) atau pakai auth ringan.
# Contoh: Postfix relay internal, AWS SES relay, SendGrid relay, dll.
SMTP_HOST=smtp-relay.example.com
SMTP_PORT=25                     # 25 (plain), 465 (SMTPS), 587 (STARTTLS)
SMTP_USERNAME=                   # kosongkan jika relay tidak butuh auth
SMTP_PASSWORD=
SMTP_USE_STARTTLS=true           # pakai STARTTLS (port 587)
SMTP_USE_TLS=false               # implicit TLS (port 465). Pilih salah satu.
SMTP_SKIP_VERIFY=false           # true hanya untuk dev/self-signed
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=IT Support
SMTP_TIMEOUT_SECONDS=15

# =========================================
# Database (audit log)
# =========================================
DB_PATH=./data/audit.db

# =========================================
# Security
# =========================================
# Panjang temporary password
TEMP_PASSWORD_LENGTH=16

# Rate limit untuk endpoint password reset (per IP per menit)
RATE_LIMIT_RESET_PER_MIN=5
# Rate limit umum API (per IP per menit)
RATE_LIMIT_API_PER_MIN=60
# Rate limit login (per IP per menit)
RATE_LIMIT_LOGIN_PER_MIN=10
