# =========================================
# FreeIPA / LDAP Configuration
# =========================================
# URL server FreeIPA, contoh: ldaps://ipa.example.com:636
LDAP_SERVER_URL=ldaps://ipa.example.com:636

# Base DN tempat user disimpan di FreeIPA
# Default FreeIPA: cn=users,cn=accounts,dc=example,dc=com
LDAP_USER_BASE_DN=cn=users,cn=accounts,dc=example,dc=com

# Service account yang punya hak reset password user lain.
# Bisa pakai admin atau buat service account khusus (recommended)
# Contoh: uid=pwreset-svc,cn=users,cn=accounts,dc=example,dc=com
LDAP_BIND_DN=uid=admin,cn=users,cn=accounts,dc=example,dc=com
LDAP_BIND_PASSWORD=ganti-password-admin-disini

# Verify TLS certificate (set false untuk self-signed cert saat development)
LDAP_USE_TLS=true
LDAP_VERIFY_CERT=true

# =========================================
# SMTP / Email Configuration
# =========================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=no-reply@example.com
SMTP_PASSWORD=smtp-password-disini
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=IT Support

# =========================================
# Application Settings
# =========================================
APP_NAME=FreeIPA Self-Service Password Reset
APP_HOST=0.0.0.0
APP_PORT=8000

# Panjang password temporary yang di-generate
TEMP_PASSWORD_LENGTH=16
